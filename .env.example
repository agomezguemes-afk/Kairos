# KAIROS — Environment configuration
#
# Copy this file to `.env` and fill in the real values. Expo inlines any
# variable prefixed with `EXPO_PUBLIC_` into the JS bundle at build time,
# so it is readable from React Native code via `process.env.EXPO_PUBLIC_*`.
#
# Restart the dev server (`npm start`) after editing `.env` — changes are
# NOT hot-reloaded.

# Groq API key — free tier, no credit card required.
# Sign up at https://console.groq.com and create a key.
# If this value is empty or missing, Kai falls back to the offline mock.
EXPO_PUBLIC_GROQ_API_KEY=
